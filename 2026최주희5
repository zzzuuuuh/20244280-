#include <stdio.h>

int main() {
    int score;

    printf("점수를 입력하세요: ");
    scanf("%d", &score);

    if(score >= 90)
        printf("등급: A\n");
    else if(score >= 80)
        printf("등급: B\n");
    else if(score >= 70)
        printf("등급: C\n");
    else if(score >= 60)
        printf("등급: D\n");
    else
        printf("등급: F\n");

    return 0;
}
