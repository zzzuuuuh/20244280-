import random

answer = random.randint(1, 100)
count = 0

print("숫자 맞추기 게임!")

while True:
    guess = int(input("1~100 사이 숫자 입력: "))
    count += 1

    if guess > answer:
        print("더 작은 숫자입니다.")
    elif guess < answer:
        print("더 큰 숫자입니다.")
    else:
        print(f"정답! 시도 횟수: {count}번")
        break
