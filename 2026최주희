#include <stdio.h>

int main() {
    int score;
    int total = 0;
    int max, min;
    
    printf("학생 5명의 점수를 입력하세요.\n");

    for (int i = 0; i < 5; i++) {
        printf("%d번째 학생 점수: ", i + 1);
        scanf("%d", &score);

        if (i == 0) {
            max = score;
            min = score;
        }

        if (score > max)
            max = score;

        if (score < min)
            min = score;

        total += score;
    }

    double average = total / 5.0;

    printf("\n===== 결과 =====\n");
    printf("총점: %d\n", total);
    printf("평균: %.2f\n", average);
    printf("최고점: %d\n", max);
    printf("최저점: %d\n", min);

    if (average >= 90)
        printf("학점: A\n");
    else if (average >= 80)
        printf("학점: B\n");
    else if (average >= 70)
        printf("학점: C\n");
    else if (average >= 60)
        printf("학점: D\n");
    else
        printf("학점: F\n");

    return 0;
}
