import java.util.Scanner;

public class Factorial {
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);

        System.out.print("숫자를 입력하세요: ");
        int n = sc.nextInt();

        long result = 1;

        for(int i = 1; i <= n; i++) {
            result *= i;
        }

        System.out.println(n + "! = " + result);

        sc.close();
    }
}
